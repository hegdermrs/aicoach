# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL (used for auth redirects in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated emails that auto-receive admin on login
ADMIN_EMAILS=kai@example.com,coach@example.com

# ElevenLabs — used only by npm run generate:audio (not at runtime)
ELEVENLABS_API_KEY=
# Put comments on their own line — inline # comments break voice/model IDs
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=

# GitHub Actions secrets (repo Settings → Secrets → Actions)
# Same values as above — used by keep-supabase-active.yml
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...
